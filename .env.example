# Copy this file to .env and fill in your values before running docker compose.
#
#   cp .env.example .env
#   docker compose up --build
#
# .env is gitignored — never commit real secrets.

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate one with:
#   openssl rand -base64 48
JWT_KEY=change-me-use-a-long-random-secret-key-at-least-32-chars

JWT_ISSUER=taskmanager
JWT_AUDIENCE=taskmanager
JWT_EXPIRY_MINUTES=60

# ── Ports ─────────────────────────────────────────────────────────────────────
# Host port the frontend (nginx) will be accessible on.
FRONTEND_PORT=80

# Uncomment if you expose the backend directly (see docker-compose.yml).
# BACKEND_PORT=5111
